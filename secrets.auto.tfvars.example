# Copy this file to secrets.auto.tfvars before apply, then fill real values.
# secrets.auto.tfvars is ignored by git.

dashscope_api_key = "sk-REPLACE_ME"

# Alibaba Cloud Model Studio Singapore Qwen-Coder endpoints usually require a workspace URL.
# Example:
# qwen_base_url = "https://<workspace-id>.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1"

# Optional: set this when using an existing Qdrant deployment instead of AWS OpenSearch.
# qdrant_url = "https://qdrant.example.com"
